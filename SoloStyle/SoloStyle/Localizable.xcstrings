    "%lld" : {
      "comment" : "A badge displaying the count of items in a filter chip. The argument is the count of items.",
      "isCommentAutoGenerated" : true
    },
    "%lld %@" : {
      "comment" : "A label displaying the number of completed visits and a message indicating how many more visits are needed to advance to the next loyalty tier. The first argument is the count of completed visits. The second argument is a string describing the pluralization of \"visit\" based on the count.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$lld %2$@"
          }
        }
      }
    },
    "%lld готово" : {
      "comment" : "A label indicating that a certain number of appointments on the current day have been marked as \"completed\". The number is provided as a string.",
      "isCommentAutoGenerated" : true
    },
    "%lld записей" : {
      "comment" : "A label with a calendar icon and a count of appointments for the current day.",
      "isCommentAutoGenerated" : true
    },
    "%lld мин" : {
      "comment" : "A small label below the appointment time that shows how long the associated service will take. The argument is the duration of the service in minutes.",
      "isCommentAutoGenerated" : true
    },
