    },
    "«%@»" : {
      "comment" : "A label displaying the transcribed text from a voice recording. The text inside the quotation marks is replaced with the actual transcribed text.",
      "isCommentAutoGenerated" : true
    },
    "@%@" : {
      "comment" : "A label displaying a user's username, shown below their name.",
      "isCommentAutoGenerated" : true
    },
    "#%lld" : {
      "comment" : "A rank label followed by a service name and the number of bookings for that service, all displayed in a glass card. The first argument is the rank of the service. The second argument is the name of the service",
      "isCommentAutoGenerated" : true
    },
    "%@ %@" : {
      "comment" : "A text label showing the user's membership date.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ %2$@"
          }
        }
      }
    },
